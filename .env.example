# LLM Configuration
LLM_MODEL=gpt-5.4-nano
LLM_API_KEY=sk-your-api-key-here

# Fallback (auto-activates if primary is unreachable, e.g., local model down)
LLM_FALLBACK_API_KEY=sk-your-openai-key

# For local models (LM Studio / Ollama):
# LLM_MODEL=openai/qwen/qwen3-4b-2507
# LLM_API_KEY=lm-studio
# LLM_API_BASE=http://localhost:1234/v1

# Embedding Model (runs locally, no API cost)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
