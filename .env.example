# LLM Configuration (LiteLLM - supports any provider)
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=sk-your-api-key-here

# Alternative models (uncomment to switch):
# LLM_MODEL=claude-sonnet-4-20250514
# LLM_API_KEY=sk-ant-your-key-here
# LLM_MODEL=groq/llama-3.1-70b-versatile
# LLM_API_KEY=gsk_your-groq-key-here

# Embedding Model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Dataset Path
DATASET_PATH=../data/family_office_dataset.xlsx

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
