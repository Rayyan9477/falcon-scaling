# Primary LLM Configuration (OpenAI SDK)
# Supported models: gpt-4o, gpt-4o-mini, gpt-4-turbo, o1, o3, etc.
LLM_MODEL=gpt-4o
LLM_API_KEY=sk-your-openai-api-key-here

# Fallback (auto-activates if primary is unreachable, e.g., local model down)
LLM_FALLBACK_API_KEY=

# For local models (LM Studio / Ollama):
# LLM_MODEL=qwen/qwen3-4b
# LLM_API_KEY=lm-studio
# LLM_API_BASE=http://localhost:1234/v1

# Embedding Model (runs locally, no API cost)
EMBEDDING_MODEL=text-embedding-3-small

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
