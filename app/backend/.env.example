# Primary LLM Configuration (LiteLLM — supports any provider)
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=sk-your-api-key-here

# For local models (LM Studio, Ollama):
# LLM_MODEL=openai/qwen/qwen3-4b-2507
# LLM_API_KEY=lm-studio
# LLM_API_BASE=http://localhost:1234/v1

# Fallback LLM: auto-activates when primary model is unreachable (e.g., local model down)
LLM_FALLBACK_API_KEY=sk-your-openai-fallback-key

# Embedding Model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Dataset path (default resolves from config.py location)
# DATASET_PATH=../../data/family_office_dataset.xlsx

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
