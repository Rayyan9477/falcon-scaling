# LLM Configuration (LiteLLM — supports any provider)
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=sk-your-api-key-here

# Alternative models (uncomment to switch):
# LLM_MODEL=claude-sonnet-4-20250514
# LLM_API_KEY=sk-ant-your-key-here

# Embedding Model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Dataset path (default works for local dev from backend/ directory)
# For Docker: overridden to /app/data/family_office_dataset.xlsx via docker-compose.yml
# DATASET_PATH=../../data/family_office_dataset.xlsx

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
