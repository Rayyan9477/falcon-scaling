# FAISS index — COMMITTED for fast cold starts on deployment
# These are pre-computed embeddings, not secrets.
# Uncomment the lines below if you want to rebuild on every deploy:
# app/backend/index/*.faiss
# app/backend/index/*.pkl
# app/backend/index/*.json
!app/backend/index/.gitkeep

